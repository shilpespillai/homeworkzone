# HomeworkZone Dedicated Firebase Configuration Template
# Copy this file to '.env' and replace the values below with your new HomeworkZone Firebase project credentials!

VITE_FIREBASE_API_KEY=your_actual_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=homeworkzone-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=homeworkzone-app
VITE_FIREBASE_STORAGE_BUCKET=homeworkzone-app.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
VITE_FIREBASE_MEASUREMENT_ID=G-ABCDEF1234
